{
  "name": "@webdeveric/prevent-shortcut-takeover-web-ext",
  "private": true,
  "type": "module",
  "version": "0.6.0",
  "license": "MIT",
  "description": "Stop sites from taking over your keyboard shortcuts",
  "keywords": [
    "WebExtension",
    "web-extension",
    "prevent",
    "shortcut",
    "takeover"
  ],
  "author": {
    "email": "eric@webdeveric.com",
    "name": "Eric King",
    "url": "http://webdeveric.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webdeveric/prevent-shortcut-takeover-web-ext.git"
  },
  "bugs": {
    "url": "https://github.com/webdeveric/prevent-shortcut-takeover-web-ext/issues"
  },
  "homepage": "https://github.com/webdeveric/prevent-shortcut-takeover-web-ext",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "lint": "eslint ./*.{js,mjs,cjs,ts,mts,cts} ./src --ext .ts,.tsx,.js --fix",
    "spellcheck": "cspell \"./{.github,src,typings}/**/*\" \"./*.{md,js,mjs,cjs,ts,mts,cts,json}\"",
    "format": "prettier --write .",
    "web-ext": "web-ext build",
    "postweb-ext": "web-ext lint",
    "prebuild": "pnpm spellcheck",
    "build": "NODE_OPTIONS='--experimental-json-modules --no-warnings' webpack --mode production",
    "build:dev": "NODE_OPTIONS='--experimental-json-modules --no-warnings' webpack --mode development",
    "start": "NODE_OPTIONS='--experimental-json-modules --no-warnings' webpack --mode development --watch",
    "start:prod": "NODE_OPTIONS='--experimental-json-modules --no-warnings' webpack --mode production --watch",
    "presign": "pnpm build",
    "sign": "web-ext sign",
    "test": "vitest --passWithNoTests",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --build --verbose --noEmit",
    "version": "sync-package-version ./src/manifest.json | xargs git add",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix"
    ],
    "*.{js,jsx,ts,tsx,json,md,css}": [
      "cspell lint --no-progress --no-summary --no-must-find-files",
      "prettier --write"
    ]
  },
  "browserslist": [
    "Firefox >= 140"
  ],
  "dependencies": {
    "@types/webextension-polyfill": "^0.12.5",
    "@webdeveric/utils": "^0.76.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@tailwindcss/webpack": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "@webdeveric/eslint-config-ts": "^0.12.0",
    "@webdeveric/prettier-config": "^0.4.0",
    "@webdeveric/sync-package-version": "^0.7.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cspell": "^10.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.9.0",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "web-ext": "^10.1.0",
    "web-ext-plugin": "^2.13.0",
    "webpack": "^5.106.1",
    "webpack-assets-manifest": "^6.5.1",
    "webpack-cli": "^7.0.2"
  }
}
